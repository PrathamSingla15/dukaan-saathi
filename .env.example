# Dukaan Saathi — optional environment overrides.
# All values have sensible defaults (tuned for the vitallab2 cluster); copy this
# to `.env` and uncomment only what you want to change.

# --- LLM (llama-server, OpenAI-compatible) ---
# DUKAAN_LLM_BASE_URL=http://127.0.0.1:8080/v1
# DUKAAN_LLM_MODEL=gemma-4-12b
# DUKAAN_LLM_ENABLE_THINKING=false     # Gemma-4 reasoning mode is slow + can blank the reply; keep off
# DUKAAN_AGENT_RECURSION_LIMIT=60

# --- llama-server launch (scripts/serve_llm.sh) ---
# DUKAAN_LLM_PORT=8080
# DUKAAN_LLM_CTX=32768
# DUKAAN_LLM_NGL=99                    # GPU layers (99 = full offload)

# --- STT (faster-whisper, ffmpeg-free) ---
# DUKAAN_WHISPER_MODEL=large-v3
# DUKAAN_WHISPER_DEVICE=cuda
# DUKAAN_WHISPER_COMPUTE=float16

# --- TTS ---
# DUKAAN_TTS_ENGINE=mms                # mms (open, default) | parler (GATED — see README)
# DUKAAN_TTS_DEVICE=cuda

# --- Gradio ---
# DUKAAN_GRADIO_HOST=0.0.0.0
# DUKAAN_GRADIO_PORT=7860
# DUKAAN_GRADIO_SHARE=false            # true → public https://*.gradio.live link

# --- business rules ---
# DUKAAN_EXPIRY_WARN_DAYS=15
# DUKAAN_LOW_STOCK_THRESHOLD=10
# DUKAAN_UDHAAR_OVERDUE_DAYS=7
# DUKAAN_FESTIVAL_LOOKAHEAD_DAYS=30
# DUKAAN_SLOW_MOVER_DAYS=21
